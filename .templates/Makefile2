.PHONY: help info colors build bt docker cdb prepare install deploy

.DEFAULT_GOAL := help

include ${DEV_MAKE}/colours.mk

TARGET_SSH_HOST=mobicast.local

DEBIAN_FOLDER=./debian
SYSTEM_CONFIG_FOLDER=${DEBIAN_FOLDER}/config
SOURCE_FOLDER=${DEBIAN_FOLDER}/package/usr/share/java/mobicast
TARGET_FOLDER=/usr/share/java/mobicast

# Date muss an 'shell' weitergereicht werden
BACKUP_FILE=".backup/data_$(shell date +'%Y%m%d_%H%M%S').tgz"

# Include wird nur ausgeführt wenn das
# File auch vorhanden ist
EXTRA_INCLUDES:=$(wildcard .config.*)
ifneq ($(strip $(EXTRA_INCLUDES)),)
  include $(EXTRA_INCLUDES)
endif

